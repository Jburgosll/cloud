# Copia este archivo como ".env" y completa los valores reales.
# El archivo ".env" NUNCA se sube a git (ya está en .gitignore).

DJANGO_SECRET_KEY=cambia-esta-clave-por-una-generada
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Punto 3: Base de datos en RDS (MySQL) ---
# Dejar USE_RDS=False para seguir usando SQLite local mientras desarrollas.
# Cuando la instancia de RDS esté creada, pon USE_RDS=True y completa estos datos
# (Host = endpoint de la instancia RDS, visible en la consola de AWS).
USE_RDS=False
RDS_DB_NAME=netflixdb
RDS_DB_USER=admin
RDS_DB_PASSWORD=cambia-esta-clave
RDS_DB_HOST=tu-instancia.xxxxxxxxxx.us-east-1.rds.amazonaws.com
RDS_DB_PORT=3306

# --- Servicio adicional: Amazon S3 (solo las imagenes/posters) ---
# Dejar USE_S3=False para guardar las imagenes en local (carpeta media/).
# Cuando el bucket y el usuario IAM estén creados, pon USE_S3=True y completa:
USE_S3=False
AWS_ACCESS_KEY_ID=tu-access-key-id
AWS_SECRET_ACCESS_KEY=tu-secret-access-key
AWS_STORAGE_BUCKET_NAME=nombre-de-tu-bucket
AWS_S3_REGION_NAME=us-east-1
